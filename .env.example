# Database - PostgreSQL (required for production)
# Use Supabase (free): https://supabase.com
# Or Vercel Postgres: https://vercel.com/storage/postgres
DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"
DIRECT_DATABASE_URL="postgresql://postgres:password@db.xxx.supabase.co:5432/postgres"

# AI - OpenRouter API Key (required for AI features)
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your-openrouter-api-key-here

# App URL (optional, for sharing)
NEXT_PUBLIC_URL=https://your-domain.com
